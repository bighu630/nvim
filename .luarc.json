{
    "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
    "Lua.diagnostics.disable": [
        "deprecated",
        "unused-local",
        "duplicate-index",
        "redefined-local",
        "need-check-nil"
    ],
    "Lua.diagnostics.globals": [
        "vim",
        "packer_plugins",
        "require",
        "error",
        "tostring",
        "new_maker"
    ]
}